<?xml version="1.0"?>
<robot name="excavator" xmlns:xacro="http://www.ros.org/wiki/xacro">
  
  <!-- 参数定义 -->
  <xacro:property name="chassis_length" value="2.5"/>
  <xacro:property name="chassis_width" value="1.2"/>
  <xacro:property name="chassis_height" value="0.4"/>
  <xacro:property name="track_width" value="0.3"/>
  <xacro:property name="track_radius" value="0.25"/>
  
  <xacro:property name="cabin_length" value="1.6"/>
  <xacro:property name="cabin_width" value="0.8"/>
  <xacro:property name="cabin_height" value="1.0"/>
  
  <xacro:property name="boom_length" value="2.5"/>
  <xacro:property name="boom_width" value="0.3"/>
  <xacro:property name="boom_height" value="0.4"/>
  
  <xacro:property name="arm_length" value="2.0"/>
  <xacro:property name="arm_width" value="0.25"/>
  <xacro:property name="arm_height" value="0.3"/>
  
  <xacro:property name="bucket_length" value="0.8"/>
  <xacro:property name="bucket_width" value="0.6"/>
  <xacro:property name="bucket_height" value="0.5"/>

  <!-- 材质定义 -->
  <material name="yellow">
    <color rgba="1.0 0.8 0.0 1.0"/>
  </material>
  <material name="black">
    <color rgba="0.1 0.1 0.1 1.0"/>
  </material>
  <material name="gray">
    <color rgba="0.5 0.5 0.5 1.0"/>
  </material>
  <material name="orange">
    <color rgba="1.0 0.5 0.0 1.0"/>
  </material>

  <!-- 惯性宏 -->
  <xacro:macro name="box_inertia" params="m x y z">
    <inertia ixx="${m*(y*y+z*z)/12}" ixy="0" ixz="0"
             iyy="${m*(x*x+z*z)/12}" iyz="0"
             izz="${m*(x*x+y*y)/12}"/>
  </xacro:macro>

  <xacro:macro name="cylinder_inertia" params="m r l">
    <inertia ixx="${m*(3*r*r+l*l)/12}" ixy="0" ixz="0"
             iyy="${m*(3*r*r+l*l)/12}" iyz="0"
             izz="${m*r*r/2}"/>
  </xacro:macro>

  <!-- ========== 底盘 ========== -->
  <link name="base_footprint"/>
  
  <link name="chassis">
    <visual>
      <geometry>
        <box size="${chassis_length} ${chassis_width} ${chassis_height}"/>
      </geometry>
      <material name="yellow"/>
    </visual>
    <collision>
      <geometry>
        <box size="${chassis_length} ${chassis_width} ${chassis_height}"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="5000"/>
      <xacro:box_inertia m="5000" x="${chassis_length}" y="${chassis_width}" z="${chassis_height}"/>
    </inertial>
  </link>

  <joint name="base_joint" type="fixed">
    <parent link="base_footprint"/>
    <child link="chassis"/>
    <origin xyz="0 0 ${track_radius + chassis_height/2}" rpy="0 0 0"/>
  </joint>

  <!-- 左履带 -->
  <link name="left_track">
    <visual>
      <geometry>
        <box size="${chassis_length} ${track_width} ${track_radius*2}"/>
      </geometry>
      <material name="black"/>
    </visual>
    <collision>
      <geometry>
        <box size="${chassis_length} ${track_width} ${track_radius*2}"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="500"/>
      <xacro:box_inertia m="500" x="${chassis_length}" y="${track_width}" z="${track_radius*2}"/>
    </inertial>
  </link>

  <joint name="left_track_joint" type="fixed">
    <parent link="chassis"/>
    <child link="left_track"/>
    <origin xyz="0 ${chassis_width/2 + track_width/2} ${-chassis_height/2}" rpy="0 0 0"/>
  </joint>

  <!-- 右履带 -->
  <link name="right_track">
    <visual>
      <geometry>
        <box size="${chassis_length} ${track_width} ${track_radius*2}"/>
      </geometry>
      <material name="black"/>
    </visual>
    <collision>
      <geometry>
        <box size="${chassis_length} ${track_width} ${track_radius*2}"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="500"/>
      <xacro:box_inertia m="500" x="${chassis_length}" y="${track_width}" z="${track_radius*2}"/>
    </inertial>
  </link>

  <joint name="right_track_joint" type="fixed">
    <parent link="chassis"/>
    <child link="right_track"/>
    <origin xyz="0 ${-chassis_width/2 - track_width/2} ${-chassis_height/2}" rpy="0 0 0"/>
  </joint>

  <!-- ========== 座舱回转平台 ========== -->
  <link name="turret">
    <visual>
      <origin xyz="0 0 ${cabin_height/2}"/>
      <geometry>
        <box size="${cabin_length} ${cabin_width} ${cabin_height}"/>
      </geometry>
      <material name="yellow"/>
    </visual>
    <collision>
      <origin xyz="0 0 ${cabin_height/2}"/>
      <geometry>
        <box size="${cabin_length} ${cabin_width} ${cabin_height}"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 ${cabin_height/2}"/>
      <mass value="2000"/>
      <xacro:box_inertia m="2000" x="${cabin_length}" y="${cabin_width}" z="${cabin_height}"/>
    </inertial>
  </link>

  <joint name="swing_joint" type="continuous">
    <parent link="chassis"/>
    <child link="turret"/>
    <origin xyz="0 0 ${chassis_height/2}" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <dynamics damping="5.0" friction="1.0"/>
    <!-- <limit effort="10000" velocity="1.0"/> -->
  </joint>

  <!-- ========== 大臂 (Boom) ========== -->
  <link name="boom">
    <visual>
      <origin xyz="${boom_length/2} 0 0"/>
      <geometry>
        <box size="${boom_length} ${boom_width} ${boom_height}"/>
      </geometry>
      <material name="orange"/>
    </visual>
    <collision>
      <origin xyz="${boom_length/2} 0 0"/>
      <geometry>
        <box size="${boom_length} ${boom_width} ${boom_height}"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="${boom_length/2} 0 0"/>
      <mass value="800"/>
      <xacro:box_inertia m="800" x="${boom_length}" y="${boom_width}" z="${boom_height}"/>
    </inertial>
  </link>

  <joint name="boom_joint" type="revolute">
    <parent link="turret"/>
    <child link="boom"/>
    <origin xyz="${cabin_length/2} 0 ${cabin_height}" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <dynamics damping="100.0" friction="10.0"/>
    <limit lower="-1.5" upper="0.5" effort="1000000" velocity="0.5"/>
  </joint>

  <!-- ========== 小臂 (Arm/Stick) ========== -->
  <link name="arm">
    <visual>
      <origin xyz="${arm_length/2} 0 0"/>
      <geometry>
        <box size="${arm_length} ${arm_width} ${arm_height}"/>
      </geometry>
      <material name="orange"/>
    </visual>
    <collision>
      <origin xyz="${arm_length/2} 0 0"/>
      <geometry>
        <box size="${arm_length} ${arm_width} ${arm_height}"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="${arm_length/2} 0 0"/>
      <mass value="400"/>
      <xacro:box_inertia m="400" x="${arm_length}" y="${arm_width}" z="${arm_height}"/>
    </inertial>
  </link>

  <joint name="arm_joint" type="revolute">
    <parent link="boom"/>
    <child link="arm"/>
    <origin xyz="${boom_length} 0 0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <dynamics damping="100.0" friction="100.0"/>
    <limit lower="-1.0" upper="2.5" effort="30000" velocity="0.6"/>
  </joint>

  <!-- ========== 铲斗 (Bucket) ========== -->
  <link name="bucket">
    <visual>
      <origin xyz="${bucket_length/2} 0 ${-bucket_height/2}"/>
      <geometry>
        <box size="${bucket_length} ${bucket_width} ${bucket_height}"/>
      </geometry>
      <material name="gray"/>
    </visual>
    <collision>
      <origin xyz="${bucket_length/2} 0 ${-bucket_height/2}"/>
      <geometry>
        <box size="${bucket_length} ${bucket_width} ${bucket_height}"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="${bucket_length/2} 0 ${-bucket_height/2}"/>
      <mass value="200"/>
      <xacro:box_inertia m="200" x="${bucket_length}" y="${bucket_width}" z="${bucket_height}"/>
    </inertial>
  </link>

  <joint name="bucket_joint" type="revolute">
    <parent link="arm"/>
    <child link="bucket"/>
    <origin xyz="${arm_length} 0 0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <dynamics damping="50.0" friction="50.0"/>
    <limit lower="-1.5" upper="1.5" effort="15000" velocity="0.8"/>
  </joint>

  <!-- 铲斗末端（用于轨迹跟踪） -->
  <link name="bucket_tip">
    <visual>
      <geometry>
        <sphere radius="0.05"/>
      </geometry>
      <material name="red">
        <color rgba="1 0 0 1"/>
      </material>
    </visual>
    <inertial>
      <mass value="0.1"/>
      <inertia ixx="0.0001" ixy="0" ixz="0" iyy="0.0001" iyz="0" izz="0.0001"/>
    </inertial>
  </link>

  <joint name="bucket_tip_joint" type="fixed">
    <parent link="bucket"/>
    <child link="bucket_tip"/>
    <origin xyz="${bucket_length} 0 ${-bucket_height}" rpy="0 0 0"/>
  </joint>

  <!-- ========== Gazebo 插件 ========== -->
  <!-- 平面移动插件 -->
  <gazebo>
    <plugin name="planar_move_controller" filename="libgazebo_ros_planar_move.so">
      <commandTopic>/excavator/cmd_vel</commandTopic>
      <odometryTopic>odom</odometryTopic>
      <odometryFrame>odom</odometryFrame>
      <robotBaseFrame>base_footprint</robotBaseFrame>
      <odometryRate>50.0</odometryRate>
      <publishOdometryTf>true</publishOdometryTf>
    </plugin>
  </gazebo>

  <!-- ROS Control插件 -->
  <gazebo>
    <plugin name="gazebo_ros_control" filename="libgazebo_ros_control.so">
      <robotNamespace>/excavator</robotNamespace>
      <robotSimType>gazebo_ros_control/DefaultRobotHWSim</robotSimType>
      <legacyModeNS>true</legacyModeNS>
    </plugin>
  </gazebo>

  <!-- 关节传动装置 -->
  <transmission name="swing_trans">
    <type>transmission_interface/SimpleTransmission</type>
    <joint name="swing_joint">
      <hardwareInterface>hardware_interface/EffortJointInterface</hardwareInterface>
    </joint>
    <actuator name="swing_motor">
      <hardwareInterface>hardware_interface/EffortJointInterface</hardwareInterface>
      <mechanicalReduction>1</mechanicalReduction>
    </actuator>
  </transmission>

  <transmission name="boom_trans">
    <type>transmission_interface/SimpleTransmission</type>
    <joint name="boom_joint">
      <hardwareInterface>hardware_interface/EffortJointInterface</hardwareInterface>
    </joint>
    <actuator name="boom_motor">
      <hardwareInterface>hardware_interface/EffortJointInterface</hardwareInterface>
      <mechanicalReduction>1</mechanicalReduction>
    </actuator>
  </transmission>

  <transmission name="arm_trans">
    <type>transmission_interface/SimpleTransmission</type>
    <joint name="arm_joint">
      <hardwareInterface>hardware_interface/EffortJointInterface</hardwareInterface>
    </joint>
    <actuator name="arm_motor">
      <hardwareInterface>hardware_interface/EffortJointInterface</hardwareInterface>
      <mechanicalReduction>1</mechanicalReduction>
    </actuator>
  </transmission>

  <transmission name="bucket_trans">
    <type>transmission_interface/SimpleTransmission</type>
    <joint name="bucket_joint">
      <hardwareInterface>hardware_interface/EffortJointInterface</hardwareInterface>
    </joint>
    <actuator name="bucket_motor">
      <hardwareInterface>hardware_interface/EffortJointInterface</hardwareInterface>
      <mechanicalReduction>1</mechanicalReduction>
    </actuator>
  </transmission>

  <!-- Gazebo材质 -->
  <gazebo reference="chassis">
    <material>Gazebo/Yellow</material>
  </gazebo>
  <gazebo reference="left_track">
    <material>Gazebo/Black</material>
    <mu1>1.5</mu1>
    <mu2>1.5</mu2>
  </gazebo>
  <gazebo reference="right_track">
    <material>Gazebo/Black</material>
    <mu1>1.5</mu1>
    <mu2>1.5</mu2>
  </gazebo>
  <gazebo reference="turret">
    <material>Gazebo/Yellow</material>
  </gazebo>
  <gazebo reference="boom">
    <material>Gazebo/Orange</material>
  </gazebo>
  <gazebo reference="arm">
    <material>Gazebo/Orange</material>
  </gazebo>
  <gazebo reference="bucket">
    <material>Gazebo/Grey</material>
  </gazebo>
  <gazebo reference="bucket_tip">
    <material>Gazebo/Red</material>
  </gazebo>
</robot>